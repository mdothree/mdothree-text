# =============================================================================
# mdothree — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and never committed.
#
# For local development (no build step), also update:
#   public/js/config/env.local.js
# =============================================================================


# ── Firebase ──────────────────────────────────────────────────────────────────
# Get these from: Firebase Console → Project Settings → Your apps → Web app
#
FIREBASE_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
FIREBASE_MESSAGING_SENDER_ID=000000000000
FIREBASE_APP_ID=1:000000000000:web:0000000000000000000000
FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX


# ── Stripe ────────────────────────────────────────────────────────────────────
# Publishable key: Stripe Dashboard → Developers → API Keys
# Price IDs: Stripe Dashboard → Products → (your Pro product) → Pricing
#
# Use pk_test_... keys during development, pk_live_... in production.
# Price IDs look like: price_1OXXXXXXXXXXXx
#
STRIPE_PUBLISHABLE_KEY=pk_live_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_PRICE_MONTHLY=price_XXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_PRICE_YEARLY=price_XXXXXXXXXXXXXXXXXXXXXXXX


# ── Firebase Cloud Functions ──────────────────────────────────────────────────
# The base URL of your deployed Firebase Functions (no trailing slash).
# Find it after deploying: firebase deploy --only functions
# Format: https://us-central1-YOUR_PROJECT_ID.cloudfunctions.net
#
FIREBASE_FUNCTION_BASE_URL=https://us-central1-your-project-id.cloudfunctions.net


# ── App ───────────────────────────────────────────────────────────────────────
# 'development' | 'production'
#
APP_ENV=production
